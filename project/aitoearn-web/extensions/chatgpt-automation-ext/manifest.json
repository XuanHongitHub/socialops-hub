{
   "action": {
      "default_title": "ChatGPT Automation - Auto ChatGPT on chatgpt.com"
   },
   "author": {
      "email": "kylenguyenaws@gmail.com"
   },
   "background": {
      "service_worker": "service-worker-loader.js",
      "type": "module"
   },
   "content_scripts": [
      {
         "all_frames": false,
         "js": [
            "assets/index.ts-BlbxxLGe.js"
         ],
         "matches": [
            "*://chatgpt.com/*"
         ],
         "run_at": "document_end"
      }
   ],
   "description": "Auto ChatGPT for your prompts at scale. Batch generate and auto-download responses and images on ChatGPT.com.",
   "host_permissions": [
      "*://chatgpt.com/*",
      "*://*.chatgpt.com/*",
      "*://chat.openai.com/*",
      "*://*.openai.com/*",
      "*://127.0.0.1:6061/*",
      "*://localhost:6061/*",
      "http://127.0.0.1:6061/*",
      "http://localhost:6061/*",
      "https://configs.kylenguyen.me/*",
      "https://extension-config.onegreen.workers.dev/*"
   ],
   "icons": {
      "16": "src/assets/logo.png",
      "24": "src/assets/logo.png",
      "32": "src/assets/logo.png",
      "128": "src/assets/logo.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "ChatGPT Automation - Auto ChatGPT on chatgpt.com",
   "offline_enabled": true,
   "permissions": [
      "storage",
      "tabs",
      "background",
      "sidePanel",
      "activeTab",
      "downloads"
   ],
   "side_panel": {
      "default_path": "src/ui/side-panel/index.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.2.8.0",
   "version_name": "1.2.8",
   "web_accessible_resources": [
      {
         "matches": [
            "*://chatgpt.com/*"
         ],
         "resources": [
            "assets/index.ts-BlbxxLGe.js"
         ],
         "use_dynamic_url": false
      }
   ]
}
