{
  "id": "remove-author-and-compact-ui",
  "description": "Remove author kylenguyen.me header link; inject compact smaller UI CSS into side panel.",
  "enabled": true,
  "targetGlobs": ["assets/index.html-*.js"],
  "replacements": [
    {
      "id": "remove-author-cta-block",
      "find": ",us(\"div\",BE,[us(\"span\",$E,En(e.$t(\"sidePanel.header.communityCtaPrefix\")),1),us(\"a\",FE,[hs(En(e.$t(\"sidePanel.header.communityCtaLink\"))+\" \",1),t[5]||(t[5]=us(\"i\",{class:\"pi pi-external-link text-xs\",\"aria-hidden\":\"true\"},null,-1))])])",
      "replace": "",
      "required": true
    },
    {
      "id": "blank-author-href",
      "find": "FE={href:\"https://kylenguyen.me\",target:\"_blank\",rel:\"noopener noreferrer\",class:\"inline-flex items-center gap-1 text-primary hover:underline font-semibold\"}",
      "replace": "FE={href:\"#\",target:\"_self\",rel:\"noopener noreferrer\",class:\"hidden\"}",
      "required": false
    },
    {
      "id": "disable-report-bugs-author-link",
      "find": "l=()=>window.open(\"https://kylenguyen.me/?report-bugs\",\"_blank\")",
      "replace": "l=()=>{}",
      "required": false
    }
  ],
  "regexReplacements": []
}
