{
  "action": {
    "default_title": "Flow Automation - Auto Flow on Google Flow"
  },
  "author": {
    "email": "kylenguyenaws@gmail.com"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "all_frames": false,
      "js": [
        "assets/index.ts-Bt6B9Lbt.js"
      ],
      "matches": [
        "*://labs.google/*"
      ],
      "run_at": "document_end"
    }
  ],
  "description": "Auto Flow prompts at scale. Defaults: 9:16 · 10s · 1 output · 1 concurrent stream · 1080p download.",
  "host_permissions": [
    "*://labs.google/*",
    "*://*.labs.google/*",
    "*://aitestkitchen.withgoogle.com/*",
    "*://127.0.0.1:6061/*",
    "*://localhost:6061/*",
    "http://127.0.0.1:6061/*",
    "http://localhost:6061/*",
    "https://configs.kylenguyen.me/*",
    "https://extension-config.onegreen.workers.dev/*"
  ],
  "icons": {
    "16": "src/assets/logo.png",
    "24": "src/assets/logo.png",
    "32": "src/assets/logo.png",
    "128": "src/assets/logo.png"
  },
  "key": "",
  "manifest_version": 3,
  "name": "Flow Automation - Auto Flow on Google Flow",
  "offline_enabled": true,
  "permissions": [
    "storage",
    "tabs",
    "background",
    "sidePanel",
    "activeTab",
    "downloads",
    "debugger",
    "cookies"
  ],
  "side_panel": {
    "default_path": "src/ui/side-panel/index.html"
  },
  "update_url": "https://clients2.google.com/service/update2/crx",
  "version": "3.2.1.0",
  "version_name": "3.2.1-socialops",
  "web_accessible_resources": [
    {
      "matches": [
        "*://labs.google/*"
      ],
      "resources": [
        "assets/catchUploadFile.ts-DJwIizxX.js",
        "assets/index.ts-Bt6B9Lbt.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
